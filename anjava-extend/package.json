{
  "name": "anjava-extend",
  "displayName": "Anjava extend",
  "version": "0.0.1",
  "description": "개발자를 위한 무의식 자세 교정 서비스",
  "author": "양선만",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build && xcopy /e /i /y assets\\mediapipe-wasm build\\chrome-mv3-prod\\assets\\mediapipe-wasm",
    "package": "plasmo package"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-toastify": "^10.0.6"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "alarms",
      "notifications",
      "offscreen",
      "scripting",
      "storage",
      "tabs"
    ],
    "externally_connectable": {
      "matches": [
        "http://localhost:3000/*",
        "https://anjava.vercel.app/*"
      ]
    },
    "host_permissions": [
      "http://*/*",
      "https://*/*"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://anjava.vercel.app http://localhost:*"
    }
  }
}
